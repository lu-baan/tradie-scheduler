export function formatAusDate(dateStr: string | null | undefined) {
  if (!dateStr) return "Not scheduled";
  try {
    return format(new Date(dateStr), "dd/MM/yyyy");
  } catch (e) {
    return "Invalid date";
  }
}

export function formatAusDateTime(dateStr: string | null | undefined) {
  if (!dateStr) return "Not scheduled";
