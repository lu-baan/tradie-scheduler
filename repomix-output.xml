  return {
    queryKey,
    queryFn,
    enabled: !!id,
    ...queryOptions,
  } as UseQueryOptions<
    Awaited<ReturnType<typeof getJobInvoice>>,
    TError,
    TData
  > & { queryKey: QueryKey };
};

